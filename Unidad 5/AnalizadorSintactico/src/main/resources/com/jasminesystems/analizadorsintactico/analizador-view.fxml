<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.jasminesystems.analizadorsintactico.controller.AnalizadorController"
      style="-fx-background-color: linear-gradient(to bottom, #141e30, #243b55);
             -fx-padding: 25;
             -fx-font-family: 'Segoe UI';">

    <!-- TÍTULO -->
    <Label text="ANALIZADOR SINTÁCTICO"
           style="-fx-font-size: 26px;
                  -fx-text-fill: #00e6e6;
                  -fx-font-weight: bold;" />

    <!-- SUBTÍTULO -->
    <Label text="Ingrese su código para analizar"
           style="-fx-font-size: 14px;
                  -fx-text-fill: #cccccc;" />

    <!-- ENTRADA -->
    <TextArea fx:id="entrada"
              prefHeight="150"
              promptText="Ejemplo: int x = (5 + 3) * 2;"
              style="-fx-font-size: 15px;
                     -fx-control-inner-background: #f5f5f5;
                     -fx-text-fill: black;
                     -fx-background-radius: 12;
                     -fx-border-radius: 12;
                     -fx-padding: 10;" />

    <!-- BOTÓN -->
    <Button fx:id="btnAnalizar"
            text="ANALIZAR"
            onAction="#analizar"
            onMouseEntered="#hoverOn"
            onMouseExited="#hoverOff"
            style="-fx-background-color: #00c9a7;
                   -fx-text-fill: white;
                   -fx-font-size: 16px;
                   -fx-font-weight: bold;
                   -fx-background-radius: 25;
                   -fx-padding: 10 25 10 25;" />

    <!-- SALIDA -->
    <TextArea fx:id="salida"
              prefHeight="150"
              editable="false"
              style="-fx-font-size: 14px;
                     -fx-control-inner-background: #ffffff;
                     -fx-text-fill: black;
                     -fx-background-radius: 12;
                     -fx-padding: 10;" />

</VBox>